{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server (QR / LAN)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 8081
    },
    {
      "name": "Expo Android Emulator",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    },
    {
      "name": "Expo iOS Simulator",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ios"],
      "port": 8081
    },
    {
      "name": "Expo Web (Browser)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "web"],
      "port": 19006
    }
  ]
}
