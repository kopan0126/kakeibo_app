# Supabase（Supabaseダッシュボード > Settings > API で確認）
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Claude APIキーはサーバー側（Supabase Edge Function）で管理
# クライアントの .env に EXPO_PUBLIC_ で秘密キーを置かないこと
# Supabase Secrets に設定: npx supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
